PREFIX ex:      <http://example.org/instances#>
PREFIX cim:     <http://iec.ch/TC57/CIM100#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>

ex:child1 a cim:Child ;
          cim:Child.childAtt 42 ;
          cim:Child.childEnumAtt cim:EnumClass.entry1 ;
          cim:Child.OtherClass ex:other1, ex:other2 ;
          cim:Parent.parentAtt "3.14"^^xsd:float .

ex:child2 a cim:Child ;
          cim:Child.childAtt 0 ;
          cim:Child.OtherClass ex:other1 ;
          cim:Child.childEnumAtt cim:EnumClass.entry2 ;
          cim:Parent.parentAtt "2.72"^^xsd:float .

ex:child3 a cim:Child ;
          cim:Child.childAtt 1 ;
          cim:Child.childEnumAtt cim:EnumClass.entry3 ;
          cim:Child.OtherClass ex:other2 ;
          cim:Parent.parentAtt "1.41"^^xsd:float .

ex:other1 a cim:OtherClass .
ex:other2 a cim:OtherClass .