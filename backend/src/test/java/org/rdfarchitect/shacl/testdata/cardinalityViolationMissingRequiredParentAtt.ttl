PREFIX ex:      <http://example.org/instances#>
PREFIX cim:     <http://iec.ch/TC57/CIM100#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>

ex:childMissingParentAtt a cim:Child ;
              cim:Child.childAtt 42 ;
              cim:Child.childEnumAtt cim:EnumClass.entry1 ;
              cim:Child.OtherClass ex:other .

ex:childValid a cim:Child ;
          cim:Child.childAtt 0 ;
          cim:Child.childEnumAtt cim:EnumClass.entry2 ;
          cim:Child.OtherClass ex:other ;
          cim:Parent.parentAtt "2.72"^^xsd:float .

ex:other a cim:OtherClass .